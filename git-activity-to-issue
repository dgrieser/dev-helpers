def warning_url(api: GitLabApi, event: dict[str, Any]) -> str | None:
    project_id = int_or_none(event.get("project_id"))
    if project_id is None:
        return None

    try:
        base_url = project_web_url(api, project_id)
    except RuntimeError:
        return None
    if base_url is None:
        return None

    target_type = event.get("target_type")
    target_iid = int_or_none(event.get("target_iid"))
    if target_type == "MergeRequest" and target_iid is not None:
        return f"{base_url}/-/merge_requests/{target_iid}"
    if target_type == "Issue" and target_iid is not None:
        return f"{base_url}/-/issues/{target_iid}"
    if target_type == "WorkItem" and target_iid is not None:
        return f"{base_url}/-/work_items/{target_iid}"

    note = event.get("note")
    if isinstance(note, dict):
        noteable_type = note.get("noteable_type")
        noteable_iid = int_or_none(note.get("noteable_iid"))
        note_id = int_or_none(note.get("id") or event.get("target_id"))
        anchor = f"#note_{note_id}" if note_id is not None else ""
        if noteable_type == "MergeRequest" and noteable_iid is not None:
            return f"{base_url}/-/merge_requests/{noteable_iid}{anchor}"
        if noteable_type in ("Issue", "WorkItem") and noteable_iid is not None:
            path = "issues" if noteable_type == "Issue" else "work_items"
            return f"{base_url}/-/{path}/{noteable_iid}{anchor}"

    push_data = event.get("push_data") or {}
    if isinstance(push_data, dict):
        commit_to = str(push_data.get("commit_to") or "")
        commit_from = str(push_data.get("commit_from") or "")
        ref = str(push_data.get("ref") or "")
        ref_type = str(push_data.get("ref_type") or "")
        action_name = str(event.get("action_name") or "")
        if ref_type == "branch" and "deleted" in action_name:
            return base_url
        if commit_to:
            return f"{base_url}/-/commit/{commit_to}"
        if commit_from:
            return f"{base_url}/-/commit/{commit_from}"
        if ref and ref_type == "branch":
            return f"{base_url}/-/tree/{urllib.parse.quote(ref, safe='')}"

    return base_url


def url_is_filtered(url: str | None, filters: list[str]) -> bool:
    if not url or not filters:
        return False
    for raw_prefix in filters:
        prefix = raw_prefix.rstrip("/")
        if not prefix:
            continue
        if url == prefix or url.startswith(f"{prefix}/"):
            return True
    return False


