ISSUE_URL_RE = re.compile(r"/-/issues/(\d+)\b")
WORK_ITEM_URL_RE = re.compile(r"/-/work_items/(\d+)\b")
ABSOLUTE_ISSUE_URL_RE = re.compile(r"https?://[^/\s)]+/([^)\s]+?)/-/issues/(\d+)\b")
ABSOLUTE_WORK_ITEM_URL_RE = re.compile(
    r"https?://[^/\s)]+/([^)\s]+?)/-/work_items/(\d+)\b"
)
ISSUE_REF_RE = re.compile(r"(?<![\w/])#(\d+)\b")
FULL_ISSUE_REF_RE = re.compile(
    r"(?<![\w/])((?:[A-Za-z0-9_.-]+/)+[A-Za-z0-9_.-]+)#(\d+)\b"
)
# A single project name (no slash) before "#iid", e.g. "inbox#17". Resolved
# relative to the namespace of the project the reference appears in.
SAME_NAMESPACE_REF_RE = re.compile(r"(?<![\w/])([A-Za-z0-9_][A-Za-z0-9_.-]*)#(\d+)\b")
MERGE_BRANCH_RE = re.compile(r"Merge branch '([^']+)' into '([^']+)'")
INTEGRATION_BRANCHES = {"main", "master", "develop", "development", "prod", "production"}


@dataclass(frozen=True)
class IssueRef:
    project_id: int
    iid: int
    source: str
    title: str | None = None
    web_url: str | None = None

    def key(self) -> tuple[int, int]:
        return (self.project_id, self.iid)

    def as_dict(self) -> dict[str, Any]:
        data: dict[str, Any] = {
            "project_id": self.project_id,
            "iid": self.iid,
            "source": self.source,
        }
        if self.title:
            data["title"] = self.title
        if self.web_url:
            data["web_url"] = self.web_url
        return data


class GitLabApi:
    def __init__(self, *, verbose: bool = False) -> None:
        self.verbose = verbose
        self.cache: dict[str, Any] = {}
        self._current_username: str | None = None

    def get(self, path: str) -> Any:
        if path in self.cache:
            return self.cache[path]

        if self.verbose:
            print(f"glab api {path}", file=sys.stderr)

        proc = subprocess.run(
            ["glab", "api", path],
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        if self.verbose:
            if proc.stdout:
                print(proc.stdout.rstrip(), file=sys.stderr)
            if proc.stderr:
                print(proc.stderr.rstrip(), file=sys.stderr)
        if proc.returncode != 0:
            raise RuntimeError(proc.stderr.strip() or f"glab api failed: {path}")

        try:
            data = json.loads(proc.stdout or "null")
        except json.JSONDecodeError as exc:
            raise RuntimeError(f"invalid JSON from glab api {path}: {exc}") from exc

        self.cache[path] = data
        return data

    def graphql(self, query: str, variables: dict[str, str]) -> Any:
        cmd = ["glab", "api", "graphql", "--raw-field", f"query={query}"]
        for key, value in variables.items():
            cmd.extend(["--raw-field", f"{key}={value}"])

        if self.verbose:
            print(" ".join(cmd), file=sys.stderr)

        proc = subprocess.run(
            cmd,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        if self.verbose:
            if proc.stdout:
                print(proc.stdout.rstrip(), file=sys.stderr)
            if proc.stderr:
                print(proc.stderr.rstrip(), file=sys.stderr)
        if proc.returncode != 0:
            raise RuntimeError(proc.stderr.strip() or "glab api graphql failed")

        try:
            data = json.loads(proc.stdout or "null")
        except json.JSONDecodeError as exc:
            raise RuntimeError(f"invalid JSON from glab api graphql: {exc}") from exc

        if isinstance(data, dict) and data.get("errors"):
            raise RuntimeError(f"GitLab GraphQL errors: {data['errors']}")
        return data


def verbose_log(enabled: bool, message: str) -> None:
    if enabled:
        print(message, file=sys.stderr)


def warning(message: str) -> None:
    print(f"WARNING: {message}", file=sys.stderr)


def project_web_url(api: GitLabApi, project_id: int) -> str | None:
    data = api.get(f"projects/{project_id}")
    if not isinstance(data, dict):
        return None
    web_url = data.get("web_url")
    return web_url if isinstance(web_url, str) and web_url else None


def project_from_path(api: GitLabApi, path_with_namespace: str) -> dict[str, Any] | None:
    encoded = urllib.parse.quote(path_with_namespace, safe="")
    data = api.get(f"projects/{encoded}")
    return data if isinstance(data, dict) else None


def project_namespace_path(api: GitLabApi, project_id: int) -> str | None:
    data = api.get(f"projects/{project_id}")
    if not isinstance(data, dict):
        return None
    namespace = data.get("namespace")
    if isinstance(namespace, dict):
        full_path = namespace.get("full_path")
        if isinstance(full_path, str) and full_path:
            return full_path
    path_with_namespace = data.get("path_with_namespace")
    if isinstance(path_with_namespace, str) and "/" in path_with_namespace:
        return path_with_namespace.rsplit("/", 1)[0]
    return None


def issue_from_project_path(
    api: GitLabApi,
    path_with_namespace: str,
    iid: int,
    source: str,
    *,
    merge_request_refs: bool = True,
) -> list[IssueRef]:
    project = project_from_path(api, path_with_namespace)
    if project is None:
        return []

    project_id = int_or_none(project.get("id"))
    if project_id is None:
        return []

    return issues_from_project_ref(
        api,
        project_id,
        iid,
        source,
        merge_request_refs=merge_request_refs,
    )


def issue_from_project_iid(
    api: GitLabApi, project_id: int, iid: int, source: str
) -> IssueRef | None:
    try:
        data = api.get(f"projects/{project_id}/issues/{iid}")
    except RuntimeError as exc:
        verbose_log(
            api.verbose,
            f"resolve issue project={project_id} iid={iid}: not found: {exc}",
        )
        return None

    if isinstance(data, dict):
        return issue_from_api_item(data, source) or IssueRef(project_id, iid, source)
    return None


def merge_request_exists(api: GitLabApi, project_id: int, iid: int) -> bool:
    try:
        data = api.get(f"projects/{project_id}/merge_requests/{iid}")
    except RuntimeError as exc:
        verbose_log(
            api.verbose,
            f"resolve mr project={project_id} iid={iid}: not found: {exc}",
        )
        return False
    return isinstance(data, dict)


