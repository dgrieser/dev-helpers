# bash completion for dev-helpers commands
# Installed once per completed command name so bash-completion can lazy-load it.

__dh_local_branches()
{
    git branch --list --format='%(refname:short)' 2>/dev/null
}

__dh_all_branches()
{
    {
        git branch --list --format='%(refname:short)'
        git branch --list --remotes --format='%(refname:lstrip=2)' | grep -v 'HEAD' | sed 's|^origin/||'
    } 2>/dev/null | sort -u
}

__dh_tags()
{
    git tag --sort=-v:refname 2>/dev/null
}

__dh_projects()
{
    git-find-repo --list 2>/dev/null
}

__dh_changed_files()
{
    git status --porcelain 2>/dev/null | cut -c4-
}

__dh_compgen()
{
    COMPREPLY=( $(compgen -W "${1}" -- "${cur}") )
}

__dh_files()
{
    COMPREPLY=( $(compgen -f -- "${cur}") )
    compopt -o filenames 2>/dev/null
}

__dh_dirs()
{
    COMPREPLY=( $(compgen -d -- "${cur}") )
    compopt -o filenames 2>/dev/null
}

__dh_init()
{
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
}

_git-activity-to-issue()
{
    local cur prev
    __dh_init
    case "${prev}" in
        --start|--end|--per-page|--max-pages|--time-spent-slot-minutes|--filter) return 0 ;;
    esac
    __dh_compgen "--start --end --per-page --max-pages --json-array --time-spent --time-spent-book --interactive --time-spent-slot-minutes --filter -v --verbose -h --help"
    return 0
}
complete -F _git-activity-to-issue git-activity-to-issue

_git-add()
{
    local cur prev
    __dh_init
    case "${prev}" in
        -q|--query) return 0 ;;
        -s|--stage|-u|--unstage|-d|--delete|-r|--reset|-i|--ignore)
            __dh_compgen "$(__dh_changed_files)"
            return 0 ;;
    esac
    if [[ "${cur}" == -* ]]; then
        __dh_compgen "-h --help -p --print -q --query -s --stage -u --unstage -d --delete -r --reset -i --ignore"
    else
        __dh_files
    fi
    return 0
}
complete -F _git-add git-add

