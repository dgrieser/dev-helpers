_git-pipe()
{
    local cur prev
    __dh_init
    case "${prev}" in
        -r|--repo)
            __dh_compgen "$(__dh_projects)"
            return 0 ;;
        --ref)
            __dh_compgen "$(__dh_all_branches) $(__dh_tags)"
            return 0 ;;
        --source)
            __dh_compgen "push trigger schedule web api merge_request_event pipeline parent_pipeline external"
            return 0 ;;
        -s|--status)
            __dh_compgen "created waiting_for_resource preparing pending running success failed canceled skipped manual scheduled"
            return 0 ;;
        -o|--output)
            __dh_compgen "txt json"
            return 0 ;;
        --var|--grep|-n|--limit) return 0 ;;
    esac
    if [[ "${cur}" == -* ]]; then
        __dh_compgen "-h --help -r --repo --ref --var --grep --source -s --status --failed --succeeded --aborted --running --pending --manual --skipped -n --limit -a --all -o --output"
    elif [ "${COMP_CWORD}" -eq 1 ]; then
        __dh_compgen "status search"
    fi
    return 0
}
complete -F _git-pipe git-pipe

